generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BARBER
  EMPLOYEE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  haircutsCreated Haircut[]
}

model Haircut {
  id          String   @id @default(uuid())
  name        String
  tags        String[]
  duration    Int
  description String?
  modelUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}
